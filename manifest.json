{
  "manifest_version": 3,
  "name": "Sakinah",
  "version": "1.0.0",
  "description": "Find sakinah through Quran recitations by Minshawi and Abdulbaset",
  "permissions": ["offscreen", "storage"],
  "host_permissions": ["https://server10.mp3quran.net/*", "https://server7.mp3quran.net/*", "https://archive.org/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
